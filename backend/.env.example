# PostgreSQL
DATABASE_URL=postgresql+asyncpg://vault:vault_secret@db:5432/vault_db

# Security
SECRET_KEY=change-me-to-a-random-64-char-hex-string

# PEPPER  → user-ID hashing (HMAC-SHA256 lookup + Argon2 defence-in-depth)
PEPPER=change-me-to-a-random-32-char-hex-string

# PEPPER2 → password hashing (Argon2 over client SHA-256). MUST differ from PEPPER.
PEPPER2=change-me-to-another-random-32-char-hex-string

JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Random.org (optional, for SGK generation)
RANDOM_ORG_API_KEY=
